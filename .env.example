# Local-only defaults. Copy to .env or set these variables in your shell.

BOT_STUDIO_HOST=127.0.0.1
BOT_STUDIO_PORT=8790

# Required when exposing the studio to LAN or the public internet.
BOT_STUDIO_PASSWORD=change-me

# Optional: set this if NapCat is not placed next to qq-bot-studio.
NAPCAT_DIR=C:\path\to\NapCat-QCE-Windows-x64

# Optional: set this if you have a custom Windows keep-awake script.
KEEP_AWAKE_SCRIPT=C:\path\to\enable-screen-off-keep-running.ps1

# API keys should normally be entered in the web UI.
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
